# danlabrador.com v2 — environment variables
# Copy this file to `.env.local` for local dev (loaded by Next.js) and
# to `.env` for Prisma CLI. Never commit either.

# ─── Neon Postgres ────────────────────────────────────────────────────────
# From: Neon console → your project → Connection Details → "Prisma" tab
# Both pooled and direct URLs. Prisma migrate needs DIRECT_URL; runtime uses DATABASE_URL.
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── Auth.js (NextAuth v5) ────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=""
# Only needed to override in prod. Locally, Auth.js infers from the request.
# AUTH_URL="https://danlabrador.com"

# GitHub OAuth app — see README for setup steps
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Comma-separated list of emails allowed into /admin
ADMIN_EMAIL_ALLOWLIST="dan@danlabrador.com,dan@helloboolean.com"

# ─── Cloudflare R2 (media storage) ────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="danlabrador-media"
# Public URL prefix. Use a custom domain (media.danlabrador.com) in prod,
# or the r2.dev public URL Cloudflare gives you for dev.
R2_PUBLIC_URL="https://media.danlabrador.com"

# ─── Resend (transactional email) ─────────────────────────────────────────
RESEND_API_KEY=""
# Must be a verified sender/domain in Resend.
RESEND_FROM="Dan Labrador <hello@danlabrador.com>"
# Where contact-form submissions land.
CONTACT_INBOX="dan@danlabrador.com"

# ─── Buttondown (newsletter) ──────────────────────────────────────────────
BUTTONDOWN_API_KEY=""

# ─── Cloudflare Turnstile (spam protection for public forms) ──────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# ─── Public site config ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
